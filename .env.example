# Copy to .env and fill in. .env is git-ignored.
DEBUG=True
SECRET_KEY=dev-insecure-change-me
ALLOWED_HOSTS=*
TIME_ZONE=Europe/Moscow
SITE_URL=http://localhost:8012

# Local dev defaults to sqlite if DATABASE_URL is unset. In Docker Compose it is
# set to route through PgBouncer (transaction pooling).
# DATABASE_URL=postgres://upwork:upwork@pgbouncer:6432/upwork
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- provider switches: mock (default, no keys) vs real ---
JOB_PROVIDER=mock          # mock | upwork   (upwork blocked on OAuth approval)
LLM_PROVIDER=mock          # mock | anthropic
EMBEDDING_PROVIDER=mock    # mock | voyage
GITHUB_PROVIDER=mock       # mock | github
JOB_SCORER=rule            # rule | llm
DRAFT_MIN_SCORE=50         # only auto-draft cover letters at/above this score

# --- keys (only needed for the real providers above) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
VOYAGE_API_KEY=
GITHUB_TOKEN=
GITHUB_USER=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Upwork OAuth (when approved) ---
UPWORK_CLIENT_ID=
UPWORK_CLIENT_SECRET=
