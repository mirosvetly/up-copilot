# Copy to .env and fill in. .env is git-ignored.
DEBUG=True
SECRET_KEY=dev-insecure-change-me
ALLOWED_HOSTS=*
TIME_ZONE=Europe/Moscow
SITE_URL=http://localhost:8012

# Local dev defaults to sqlite if DATABASE_URL is unset. In Docker Compose it is
# set to route through PgBouncer (transaction pooling).
# DATABASE_URL=postgres://upwork:upwork@pgbouncer:6432/upwork
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- provider switches: mock (default, no keys) vs real ---
# mock | gmail | vibeworker | upwork  (upwork blocked on OAuth approval)
JOB_PROVIDER=mock
# mock | anthropic
LLM_PROVIDER=mock
# mock | voyage
EMBEDDING_PROVIDER=mock
# mock | github
GITHUB_PROVIDER=mock
# rule | llm
JOB_SCORER=rule
# движок перевода: mymemory (работает там, где Google заблокирован) | google (без дневного лимита)
TRANSLATE_ENGINE=mymemory
# only auto-draft cover letters at/above this score
DRAFT_MIN_SCORE=50
MAX_JOB_AGE_HOURS=24         # игнорировать вакансии из API старше N часов
# не тянуть перегретые вакансии: пропускать те, где Upwork требует >= N коннектов. 0 = тянуть все
COLLECT_MAX_CONNECTS=0
# не тянуть вакансии, где эти слова есть в ЗАГОЛОВКЕ (no-code платформы). Через запятую, пусто = не фильтровать
EXCLUDE_KEYWORDS=wordpress,webflow,wix,squarespace,elementor
# порог, с которого вакансия помечается «перегрета откликами» в интерфейсе
HOT_CONNECTS_THRESHOLD=16
# кто я для гео/языкового гейта скоринга (вакансии с невыполнимым требованием локации/языка тонут)
FREELANCER_LOCATION=Europe (EU), UTC+1 to UTC+3
FREELANCER_LANGUAGES=English, Russian
# бэкенд скоринга: ollama (бесплатно, локально) | anthropic | пусто = как LLM_PROVIDER. Письма остаются на LLM_PROVIDER
SCORER_LLM_PROVIDER=
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434
# держать модель в RAM между вакансиями (нет холодной загрузки ~15с). 30m | -1 (навсегда) | 0 (выгружать сразу)
OLLAMA_KEEP_ALIVE=30m

# --- keys (only needed for the real providers above) ---
# tryvibeworker.com/settings -> Developer
VIBEWORKER_API_KEY=
# Push webhook (POST /webhooks/vibeworker/), premium/optional — only useful if
# you've deployed up-copilot somewhere with a real public URL. Local/laptop
# installs should stick with JOB_PROVIDER=vibeworker polling (above); it needs
# no public URL and works behind any NAT/firewall. If you do use the webhook:
# point a Vibeworker filter's webhook URL at this app, and set that filter's
# id on the matching SavedFilter.vibeworker_filter_id (admin) for track
# assignment. Comma-separated IP allowlist; empty = accept from anywhere (no
# auth yet).
VIBEWORKER_WEBHOOK_ALLOWED_IPS=
# JOB_PROVIDER=gmail: mailbox with Upwork job alerts + Google app password
GMAIL_IMAP_USER=
GMAIL_IMAP_PASSWORD=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_SCORER_MODEL=claude-haiku-4-5-20251001
VOYAGE_API_KEY=
GITHUB_TOKEN=
GITHUB_USER=
# Telegram-пинг о хороших вакансиях: бот от @BotFather + твой chat_id (@userinfobot).
# Запуск цикла: manage.py poll_notify (по cron/launchd)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# порог пинга. ~70 под Haiku; Ollama занижает — под неё ставь ~35
NOTIFY_MIN_SCORE=70

# --- Upwork OAuth (when approved) ---
UPWORK_CLIENT_ID=
UPWORK_CLIENT_SECRET=
